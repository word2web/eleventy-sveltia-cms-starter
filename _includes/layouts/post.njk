---
layout: layouts/base.njk
section: post
---
<article>

  <h1>{{ title }}</h1>

  {% if summary %}
    <p>{{ summary }}</p>
  {% endif %}

  <p>
    <small>
      Posted on
      <time datetime="{{ page.date | machineDate }}">
        {{ page.date | readableDate }}
      </time>
      {% if tags %}
        in
        {% for tag in tags %}
          {%- if tag != "post" -%}
            {% set tagUrl %}/tags/{{ tag }}/{% endset %}
            <a href="{{ tagUrl | url }}" rel="tag">{{ tag }}</a>
            {%- if loop.last %}{% else %},{% endif -%}
          {%- endif -%}
        {% endfor %}
      {% endif %}
    </small>
  </p>

  {% if image %}
{% set safeImage = image %}
    {# If it HAS a slash, remove it for the shortcode, because the plugin 
       might be looking for the file path directly from the root #}
    {% if safeImage.startsWith('/') %}
      {% set safeImage = safeImage.substring(1) %}
    {% endif %}


    {# Use the safeImage variable in your shortcode #}
    {% generateImage safeImage, (imageAltText or title), "90vw" %}
  {% endif %}

  {{ layoutContent | safe }}

</article>

{% include "components/nav-back.njk" %}
